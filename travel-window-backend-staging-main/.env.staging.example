PORT=3000
NODE_ENV=staging

# Use staging database only (never production DB here)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<staging_db>?retryWrites=true&w=majority

# Keep secrets separate from production
JWT_SECRET=replace_with_strong_staging_secret
SEED_SECRET=replace_with_staging_seed_secret

# Optional reCAPTCHA secret for staging login checks
# RECAPTCHA_SECRET=replace_with_staging_recaptcha_secret
